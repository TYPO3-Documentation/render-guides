<div class="versionchange {{ node.type }}">
    <p class="versionmodified">
        <span class="versionicon">
        {%- if node.type=="deprecated" -%}
            <i class="fa-solid fa-ban"></i>
        {%- elseif node.type=="versionadded" -%}
            <i class="fa-solid fa-rocket"></i>
        {%- elseif node.type=="versionchanged" -%}
            <i class="fa-solid fa-arrows-rotate"></i>
        {%- endif -%}
        </span>
        {{ node.versionLabel }}
        {%- if node.changelogReference -%}
            {#- Rendering resolves the interlink (and warns if the entry does not exist). Emit the link only when it resolved to a URL. -#}
            {%- set changelogResolved = renderNode(node.changelogReference) -%}
            {%- if node.changelogReference.url %} <a class="versionchange-changelog" href="{{ node.changelogReference.url }}">See changelog entry</a>{% endif -%}
        {%- endif -%}
        </p>
    <article>
        {{ renderNode(node.value) }}
    </article>
</div>
