
{% if rootline|filter(e => not e.current and e.value is not null)|length > 0 %}
<ol class="breadcrumb">
    {% for entry in rootline -%}
        {%- if entry.current %}
            <li aria-current="page"  class="breadcrumb-item  active">{{ renderPlainText(entry.value) }}</li>
        {% else -%}
            <li class="breadcrumb-item"><a href="{{ renderLink(entry.url) }}">{{ renderPlainText(entry.value) }}</a></li>
        {% endif -%}
    {% endfor %}
</ol>
{% endif %}
