{% if has_page_context %}
    {# We're in multi-page mode #}
    {% include "structure/layoutParts/editOnGithubButtons.html.twig" %}
    {% set singleHtmlUrl = getSingleHtmlLink() %}
    {% if singleHtmlUrl %}
        <a class="dropdown-item d-flex align-items-center gap-2" href="{{ singleHtmlUrl }}" target="_blank" rel="noopener">
            <i class="fa-solid fa-print"></i>
            Full documentation (single file)
        </a>
    {% endif %}
{% else %}
    {# We're in singlehtml mode -> show link back to normal view #}
    <a class="dropdown-item d-flex align-items-center gap-2" href="../Index.html" rel="noopener">
        <i class="fa-solid fa-file-lines"></i>
        Switch to regular view
    </a>
{% endif %}
