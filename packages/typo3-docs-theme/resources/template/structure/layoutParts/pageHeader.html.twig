<header>
    <div class="page-topbar">
        <div class="page-topbar-inner">
            <typo3-universe active="documentation">
                <div style="display: block; height: 44px; background-color: #313131;"></div>
            </typo3-universe>
        </div>
    </div>
    <div class="page-header">
        <div class="page-header-inner">
            <a class="navbar-brand" href="https://docs.typo3.org/" title="TYPO3 Documentation">
                <span class="navbar-brand-text">
                    <img src="{{ getRelativePath('_resources/img/typo3-soul.svg') }}" alt="TYPO3" class="navbar-brand-logo" width="29" height="29">
                    <span class="navbar-brand-name">Documentation</span>
                </span>
            </a>
            <div class="header-nav">
                {% include "structure/navigation/navigationHeader.html.twig" %}
            </div>
            <div class="header-actions">
                <button id="search-toggle" class="btn btn-light d-lg-none" type="button"
                        aria-label="Search" aria-expanded="false" aria-controls="header-search-expand">
                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                </button>
                <button id="toc-toggle" class="btn btn-light d-lg-none" type="button"
                        aria-label="Menu" aria-expanded="false" aria-controls="toc-collapse">
                    <i class="fa-solid fa-bars" aria-hidden="true"></i>
                </button>
                {% if isRenderedForDeployment() -%}
                    <all-documentations-menu></all-documentations-menu>
                {%- else -%}
                    <all-documentations-menu data-override-url="{{ getRelativePath('_resources/js/menu-proxy.php')}}"></all-documentations-menu>
                {% endif %}
                <search id="header-search-expand" class="header-search" role="search" aria-label="Site search">
                    <form action="https://docs.typo3.org/search/search" id="global-search-form" method="get">
                        <div class="sr-only"><label for="globalsearchinput">TYPO3 documentation...</label></div>
                        <div class="input-group">
                            <select class="form-select search__scope" id="searchscope" name="scope">
                                <option value="">Search all</option>
                            </select>
                            <input autocomplete="off" class="form-control shadow-none" id="globalsearchinput" name="q" placeholder="TYPO3 documentation..." type="text" value="">
                            <button class="btn btn-light" type="submit" aria-label="Search">
                                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                                <span>Search</span>
                            </button>
                        </div>
                    </form>
                    <div id="global-search-root"></div>
                </search>
                <button id="options-toggle" class="btn btn-light" type="button"
                        aria-controls="options-panel" aria-expanded="false" popovertarget="options-panel">
                    <i class="fa-solid fa-gear" aria-hidden="true"></i>
                    <span class="visually-hidden">Options</span>
                </button>
                <div id="options-panel" class="shadow p-3" popover>
                    <h6 class="dropdown-header text-muted text-uppercase small mb-2">Options</h6>
                    {% include "structure/layoutParts/optionsMenu.html.twig" %}
                </div>
            </div>
        </div>
    </div>
</header>
